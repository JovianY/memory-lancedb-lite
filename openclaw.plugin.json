{
    "id": "memory-lancedb-lite",
    "name": "Memory (LanceDB Lite)",
    "description": "Streamlined LanceDB-backed long-term memory with hybrid retrieval, multi-scope isolation, and security hardening",
    "version": "1.1.9",
    "main": "dist/index.js",
    "kind": "memory",
    "configSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "embedding": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "provider": {
                        "type": "string",
                        "const": "openai-compatible"
                    },
                    "apiKey": {
                        "type": "string"
                    },
                    "model": {
                        "type": "string"
                    },
                    "baseURL": {
                        "type": "string"
                    },
                    "dimensions": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "taskQuery": {
                        "type": "string",
                        "description": "Embedding task for queries (e.g. retrieval.query)"
                    },
                    "taskPassage": {
                        "type": "string",
                        "description": "Embedding task for passages (e.g. retrieval.passage)"
                    },
                    "normalized": {
                        "type": "boolean",
                        "description": "Request normalized embeddings when supported"
                    }
                },
                "required": [
                    "apiKey"
                ]
            },
            "dbPath": {
                "type": "string"
            },
            "enableManagementTools": {
                "type": "boolean",
                "default": false
            },
            "autoCapture": {
                "type": "boolean",
                "default": true,
                "description": "Automatically capture user messages into long-term memory (with noise and duplicate filtering)"
            },
            "autoRecall": {
                "type": "boolean",
                "default": false
            },
            "autoRecallMinLength": {
                "type": "integer",
                "minimum": 1,
                "maximum": 200,
                "default": 15
            },
            "captureAssistant": {
                "type": "boolean",
                "default": false,
                "description": "When true, autoCapture also captures assistant messages (in addition to user messages)"
            },
            "retrieval": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "mode": {
                        "type": "string",
                        "enum": [
                            "hybrid",
                            "vector"
                        ],
                        "default": "hybrid"
                    },
                    "vectorWeight": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "default": 0.7
                    },
                    "bm25Weight": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "default": 0.3
                    },
                    "minScore": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "default": 0.3
                    },
                    "rerank": {
                        "type": "string",
                        "enum": [
                            "cross-encoder",
                            "lightweight",
                            "none"
                        ],
                        "default": "cross-encoder"
                    },
                    "rerankApiKey": {
                        "type": "string",
                        "description": "API key for reranker service"
                    },
                    "rerankModel": {
                        "type": "string",
                        "default": "jina-reranker-v3"
                    },
                    "rerankEndpoint": {
                        "type": "string",
                        "default": "https://api.jina.ai/v1/rerank"
                    },
                    "rerankProvider": {
                        "type": "string",
                        "enum": [
                            "jina",
                            "siliconflow",
                            "voyage",
                            "pinecone"
                        ],
                        "default": "jina"
                    },
                    "candidatePoolSize": {
                        "type": "integer",
                        "minimum": 10,
                        "maximum": 100,
                        "default": 20
                    },
                    "recencyHalfLifeDays": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 365,
                        "default": 14
                    },
                    "recencyWeight": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 0.5,
                        "default": 0.1
                    },
                    "filterNoise": {
                        "type": "boolean",
                        "default": true
                    },
                    "lengthNormAnchor": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 5000,
                        "default": 500
                    },
                    "hardMinScore": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "default": 0.35
                    },
                    "timeDecayHalfLifeDays": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 365,
                        "default": 60
                    }
                }
            },
            "sessionMemory": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "enabled": {
                        "type": "boolean",
                        "default": false,
                        "description": "Enable /save command and one-time handoff context injection"
                    },
                    "messageCount": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15,
                        "description": "How many recent session messages are included in /save summarization"
                    }
                }
            },
            "summarizer": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "apiKey": {
                        "type": "string",
                        "description": "API key for summarizer model. For local gateway baseURL it uses OPENCLAW_GATEWAY_TOKEN when omitted; otherwise falls back to OPENROUTER_API_KEY."
                    },
                    "model": {
                        "type": "string",
                        "default": "gpt-4o-mini"
                    },
                    "baseURL": {
                        "type": "string"
                    }
                }
            },
            "scopes": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "default": {
                        "type": "string",
                        "default": "global"
                    },
                    "definitions": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "object",
                            "properties": {
                                "description": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "agentAccess": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "required": [
            "embedding"
        ]
    },
    "uiHints": {
        "embedding.apiKey": {
            "label": "API Key",
            "sensitive": true,
            "placeholder": "sk-proj-... or ${OPENAI_API_KEY}",
            "help": "API key for the embedding provider"
        },
        "embedding.model": {
            "label": "Embedding Model",
            "placeholder": "text-embedding-3-small",
            "help": "Embedding model name"
        },
        "embedding.baseURL": {
            "label": "Base URL",
            "placeholder": "https://api.openai.com/v1",
            "help": "Custom base URL for OpenAI-compatible endpoints",
            "advanced": true
        },
        "autoCapture": {
            "label": "Auto-Capture",
            "help": "Automatically capture useful user messages into memory"
        },
        "autoRecall": {
            "label": "Auto-Recall",
            "help": "Automatically inject relevant memories into context"
        },
        "captureAssistant": {
            "label": "Capture Assistant",
            "help": "Also auto-capture assistant messages when Auto-Capture is enabled",
            "advanced": true
        },
        "sessionMemory.enabled": {
            "label": "Session Memory",
            "help": "Enable /save summarization and first-turn handoff injection"
        },
        "retrieval.rerank": {
            "label": "Reranking Mode",
            "help": "Re-score fused results for better quality",
            "advanced": true
        },
        "retrieval.rerankApiKey": {
            "label": "Reranker API Key",
            "sensitive": true,
            "advanced": true
        },
        "summarizer.apiKey": {
            "label": "Summarizer API Key",
            "sensitive": true,
            "placeholder": "Uses OPENCLAW_GATEWAY_TOKEN (local) or OPENROUTER_API_KEY",
            "advanced": true,
            "help": "LLM API Key used for /save session summarization"
        },
        "summarizer.model": {
            "label": "Summarizer Model",
            "placeholder": "gpt-4o-mini",
            "advanced": true
        },
        "enableManagementTools": {
            "label": "Management Tools",
            "help": "Enable memory_list and memory_stats tools",
            "advanced": true
        }
    }
}
