{
    "name": "memory-lancedb-lite",
    "version": "1.1.8",
    "description": "Streamlined, security-hardened LanceDB memory plugin for OpenClaw — Hybrid Retrieval, Cross-Encoder Rerank, Multi-Scope Isolation",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "npm run build && node tests/run-tests.mjs",
        "test:runtime:smoke": "npm run build && node scripts/runtime-smoke.mjs",
        "test:live:apis": "npm run build && node scripts/live-api-smoke.mjs",
        "test:e2e:save": "npm run build && bash scripts/e2e-save-smoke.sh",
        "test:all": "bash scripts/test-all.sh",
        "test:all:no-e2e": "bash scripts/test-all.sh --no-e2e",
        "test:all:e2e-only": "bash scripts/test-all.sh --e2e-only"
    },
    "dependencies": {
        "@lancedb/lancedb": "0.26.2",
        "@sinclair/typebox": "0.34.48",
        "openai": "6.21.0"
    },
    "devDependencies": {
        "typescript": "5.9.3",
        "@types/node": "22.15.0"
    },
    "openclaw": {
        "extensions": [
            "./dist/index.js"
        ]
    },
    "license": "MIT"
}
